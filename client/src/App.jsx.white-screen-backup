  const vt = VISA_TYPES[visaType];
  const prov = PROVIDERS[provider];
  const meta = { category: category.label, state, certLabel: vt.certLabel };
  const addLog = useCallback(m => setLogs(prev => [...prev, m]), []);

  async function refreshAiStatus() {
    const res = await apiFetch("/api/ai/status");
    if (res.ok) {
      const data = await res.json();
      setAiStatus(data);
      const preferred = localStorage.getItem("h2_ai_provider");
      const providers = data.providers || {};
      const selected =
        preferred && providers[preferred]?.configured && PROVIDERS[preferred]
          ? [preferred, providers[preferred]]
          : Object.entries(providers).find(([key, value]) => value.configured && PROVIDERS[key]);
      if (selected) {
        setProvider(selected[0]);
        setModel(PROVIDERS[selected[0]].models[0].id);
      }
    }
  }

  if (!authUser) return <Login onLogin={u => setAuthUser(u)} />;

  const favoriteKey = job => `${job.company || ""}|${job.position || ""}|${job.location || ""}|${job.period || ""}`;

  const isFavorite = job => favorites.some(f => favoriteKey(f) === favoriteKey(job));

  const toggleFavorite = job => {
    setFavorites(prev => {
      const key = favoriteKey(job);
      const exists = prev.some(f => favoriteKey(f) === key);
      const next = exists ? prev.filter(f => favoriteKey(f) !== key) : [{ ...job, savedAt: new Date().toISOString() }, ...prev];
      localStorage.setItem("h2_favorites", JSON.stringify(next));
      return next;
    });
  };

  const scan = async () => {
    setLoading(true); setJobs([]); setLogs([]); setSummary(null); setError(null);
    addLog(`🚀 ${visaType} — ${category.label} | ${state} | ${CURRENT_YEAR}`);
    addLog(`🤖 IA selecionada: ${aiStatus?.configured ? prov.short : "não configurada"}`);
    try {
      if (!aiStatus?.configured) throw new Error("Nenhum motor de IA configurado no servidor. Configure uma chave no .env ou no ambiente.");
      const raw = await callAPI(provider, model, buildPrompt(visaType, category, state, extra));
      const start = raw.indexOf("{"), end = raw.lastIndexOf("}");
      if (start === -1) throw new Error("JSON não encontrado na resposta da IA");
      const parsed = JSON.parse(raw.slice(start, end + 1));
      (parsed.logs || []).forEach(addLog);
      const enriched = (parsed.jobs || []).map(j => ({ ...j, matchScore: j.matchScore || calcMatch(j) }));
      setJobs(enriched); setSummary(parsed.summary || null); setTab("results");
      localStorage.setItem("h2_last_jobs", JSON.stringify(enriched));
      localStorage.setItem("h2_last_summary", JSON.stringify(parsed.summary || null));

      setHistory(h => {
        const next = [{ id: Date.now(), visaType, category: category.label, state, provider: prov.short, jobs: enriched.length, verified: parsed.summary?.verified || 0, ts: new Date().toLocaleString("pt-BR") }, ...h.slice(0, 24)];
        localStorage.setItem("h2_scan_history", JSON.stringify(next));
        return next;
      });
      addLog(`📊 ${enriched.length} vagas — ${parsed.summary?.verified || 0} verificadas`);
    } catch (err) { setError(err.message); addLog("❌ " + err.message); }
    finally { setLoading(false); }
  };

  const exportCSV = () => {
    const header = ["Empresa", "Cargo", "Local", "Vagas", "Salário", "Período", "Temporada", "Idioma", "DOL", "Cert", "NAICS", "Risco", "Aderência", "Fonte"];
    const rows = jobs.map(j => [j.company, j.position, j.location, j.openings, j.wage, j.period, inferSeasonType(j).label, inferLanguagePreference(j).label, j.dolStatus, j.dolCert, j.naicsCode, j.risk, j.matchScore || calcMatch(j), j.source].map(v => `"${String(v || "").replace(/"/g, '""')}"`).join(","));
    const a = document.createElement("a");
    a.href = URL.createObjectURL(new Blob([[header.join(","), ...rows].join("\n")], { type: "text/csv;charset=utf-8" }));
    a.download = `h2-${visaType}-${Date.now()}.csv`; a.click();
  };
  const exportJSON = () => {
    const a = document.createElement("a");
    a.href = URL.createObjectURL(new Blob([JSON.stringify({ summary, jobs, logs }, null, 2)], { type: "application/json" }));
    a.download = `h2-${visaType}-${Date.now()}.json`; a.click();
  };

  const select = { width: "100%", background: p.input, border: `1px solid ${p.border}`, color: p.text, padding: "9px 10px", borderRadius: 8, fontSize: 12, fontFamily: "inherit" };
  const topBtn = { background: p.soft, border: `1px solid ${p.border}`, color: p.sub, padding: "6px 10px", borderRadius: 7, cursor: "pointer", fontSize: 11, fontFamily: "'JetBrains Mono',monospace" };

  return <>
    <style>{`@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:wght@400;500&display=swap');html,body,#root{margin:0!important;padding:0!important;background:${p.bg};width:100%;height:100%;}*{box-sizing:border-box}@keyframes slideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}button:focus-visible,input:focus,select:focus,textarea:focus{outline:2px solid #3b82f6;outline-offset:2px}`}</style>
    <div style={{ background: p.bg, color: p.text, fontFamily: "'DM Sans',sans-serif", display: "flex", flexDirection: "column", height: "100vh", overflow: "hidden" }}>
      <header style={{ borderBottom: `1px solid ${p.border}`, padding: "12px 22px", display: "flex", alignItems: "center", justifyContent: "space-between", background: p.panel }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}><div style={{ width: 36, height: 36, borderRadius: 10, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18, background: `linear-gradient(135deg,${vt.accent},#7c3aed)` }}>🛂</div><div><div style={{ fontFamily: "'Syne',sans-serif", fontWeight: 800, fontSize: 17 }}><span style={{ color: vt.color }}>H-2 Visa</span> Scanner Pro</div><div style={{ color: p.muted, fontSize: 9, fontFamily: "'JetBrains Mono',monospace" }}>DOL VALIDATOR · IA STATUS · TEMPORADA {CURRENT_YEAR}</div></div></div>
        <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap", justifyContent: "flex-end" }}>
          {jobs.length > 0 && <><button onClick={exportCSV} style={topBtn}>⬇ CSV</button><button onClick={exportJSON} style={topBtn}>⬇ JSON</button><button onClick={() => jobs.forEach((j, i) => setTimeout(() => generatePDF(j, visaType, meta), i * 300))} style={topBtn}>📄 Todos PDFs</button></>}
          <AiStatus status={aiStatus} p={p} />
          <select value={theme} onChange={e => setTheme(e.target.value)} style={{ ...topBtn, padding: "6px 8px" }}><option value="dark">🌙 Escuro</option><option value="light">☀️ Claro</option><option value="system">💻 Sistema</option></select>
          <span style={{ color: p.muted, fontSize: 11, fontFamily: "'JetBrains Mono',monospace" }}>{authUser.username}</span>
          <button onClick={() => setShowAdmin(true)} style={topBtn}>👤 Minha Conta</button>
          {isAdmin() && <button onClick={() => setShowAdmin(true)} style={{ ...topBtn, borderColor: "#3b82f6", color: "#3b82f6" }}>⚙️ Admin</button>}
          <button onClick={() => { clearToken(); setAuthUser(null); }} style={{ ...topBtn, borderColor: "#991b1b", color: "#f87171" }}>⏏ Sair</button>
        </div>
      </header>
      <div style={{ display: "flex", flex: 1, overflow: "hidden" }}>
        <aside style={{ width: 280, flexShrink: 0, borderRight: `1px solid ${p.border}`, padding: 18, background: p.panel, overflowY: "auto" }}>
          <Sec label="Tipo de visto" p={p}><div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>{Object.entries(VISA_TYPES).map(([k, v]) => <button key={k} onClick={() => { setVisaType(k); setCategory(VISA_TYPES[k].categories[0]); setJobs([]); setLogs([]); setSummary(null); }} style={{ background: visaType === k ? `${v.accent}22` : p.card, border: `1px solid ${visaType === k ? v.color : p.border}`, color: visaType === k ? v.color : p.sub, padding: 10, borderRadius: 9, cursor: "pointer" }}><div style={{ fontSize: 20 }}>{v.icon}</div><strong>{v.label}</strong></button>)}</div></Sec>
          <Sec label="Setor" p={p}><div style={{ display: "flex", flexDirection: "column", gap: 4 }}>{vt.categories.map(c => <button key={c.id} onClick={() => setCategory(c)} style={{ background: category.id === c.id ? `${vt.accent}22` : "transparent", border: `1px solid ${category.id === c.id ? vt.color : "transparent"}`, color: category.id === c.id ? vt.color : p.sub, padding: "8px 10px", borderRadius: 7, cursor: "pointer", textAlign: "left" }}>{c.label}</button>)}</div></Sec>
          <Sec label="Estado (EUA)" p={p}><select value={state} onChange={e => setState(e.target.value)} style={select}>{US_STATES.map(s => <option key={s}>{s}</option>)}</select></Sec>
          <Sec label="Status da IA" p={p}><div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 9, padding: 12 }}><AiStatus status={aiStatus} p={p} /><div style={{ color: p.muted, fontSize: 11, marginTop: 9, lineHeight: 1.6 }}>O usuário comum não escolhe o motor. O sistema usa automaticamente o primeiro provider configurado no servidor. A escolha detalhada fica no Admin.</div><button onClick={refreshAiStatus} style={{ ...topBtn, marginTop: 10 }}>🔄 Atualizar status</button></div></Sec>
          <Sec label="Instruções adicionais" p={p}><textarea value={extra} onChange={e => setExtra(e.target.value)} placeholder="Ex: Prefiro empresas com brasileiros, mínimo $16/hr, moradia incluída..." rows={4} style={{ ...select, resize: "vertical", lineHeight: 1.5 }} /></Sec>
          <AppButton onClick={scan} disabled={loading} style={{ width: "100%", padding: "12px 0", background: loading ? p.soft : `linear-gradient(135deg,${vt.accent},#7c3aed)`, color: "#fff", fontFamily: "'Syne',sans-serif", fontWeight: 800 }}>{loading ? "⏳ Varrendo..." : `🔍 Varrer ${visaType} ${CURRENT_YEAR}`}</AppButton>
          {error && <div style={{ background: "#1c0a0a", border: "1px solid #991b1b", color: "#fca5a5", padding: 10, borderRadius: 8, fontSize: 12, marginTop: 10 }}>{error}</div>}
          <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 8, padding: 10, marginTop: 10, color: p.muted, fontSize: 11, lineHeight: 1.6 }}>{vt.dolInfo}</div>
        </aside>
        <main style={{ flex: 1, padding: "20px 24px", overflowY: "auto", background: p.bg }}>
          {jobs.length > 0 && <div style={{ display: "grid", gridTemplateColumns: "repeat(5, minmax(120px,1fr))", gap: 10, marginBottom: 18 }}>{[["Total", jobs.length, vt.color, "📋"], ["Verificadas", jobs.filter(j => j.dolStatus === "VERIFIED").length, "#22c55e", "✅"], ["Pendentes", jobs.filter(j => j.dolStatus === "PENDING").length, "#f59e0b", "⏳"], ["Não encontradas", jobs.filter(j => j.dolStatus === "NOT_FOUND").length, "#ef4444", "❌"], ["Risco baixo", jobs.filter(j => j.risk === "LOW").length, "#8b5cf6", "🟢"]].map(([l, v, c, i]) => <div key={l} style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 14, textAlign: "center", boxShadow: p.shadow }}><div>{i}</div><div style={{ color: c, fontSize: 24, fontWeight: 800, fontFamily: "'JetBrains Mono',monospace" }}>{v}</div><div style={{ color: p.muted, fontSize: 9, textTransform: "uppercase" }}>{l}</div></div>)}</div>}
          {(jobs.length > 0 || logs.length > 0) && <div style={{ display: "flex", gap: 4, borderBottom: `1px solid ${p.border}`, marginBottom: 16 }}>{[["results", `📋 Resultados (${jobs.length})`], ["favorites", `⭐ Favoritos (${favorites.length})`], ["terminal", "⚡ Terminal"], ["history", "🕘 Histórico"]].map(([t, l]) => <button key={t} onClick={() => setTab(t)} style={{ background: "transparent", border: "none", borderBottom: tab === t ? `2px solid ${vt.color}` : "2px solid transparent", color: tab === t ? vt.color : p.muted, padding: "9px 14px", cursor: "pointer", fontWeight: 800 }}>{l}</button>)}</div>}
          {tab === "results" && <>{summary && <div style={{ background: "#052e16", border: "1px solid #166534", color: "#bbf7d0", borderRadius: 10, padding: 16, marginBottom: 16 }}><strong style={{ color: "#4ade80" }}>💡 Recomendação Estratégica</strong>{summary.bestPick && <div style={{ marginTop: 6 }}>🏆 {summary.bestPick}</div>}<div style={{ marginTop: 5 }}>{summary.recommendation}</div></div>}{jobs.length > 0 ? jobs.map((j, i) => <JobCard key={i} job={j} idx={i} vt={vt} p={p} visaType={visaType} meta={meta} isFavorite={isFavorite} onToggleFavorite={toggleFavorite} />) : !loading && <Empty vt={vt} p={p} />}</>}
          {tab === "favorites" && <div>
            {favorites.length ? favorites.map((j, i) => (
              <JobCard key={favoriteKey(j)} job={j} idx={i} vt={vt} p={p} visaType={visaType} meta={meta} isFavorite={isFavorite} onToggleFavorite={toggleFavorite} />
            )) : <div style={{ color: p.muted, background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 20 }}>
              Nenhuma vaga salva ainda. Clique em <strong>☆ Salvar</strong> em qualquer vaga para adicioná-la aqui.
            </div>}
          </div>}

          {tab === "dashboard" && <div>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit,minmax(180px,1fr))", gap: 10, marginBottom: 16 }}>
              <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 16 }}>
                <div style={{ color: p.muted, fontSize: 11 }}>Vagas salvas</div>
                <div style={{ color: vt.color, fontSize: 30, fontWeight: 800 }}>{favorites.length}</div>
              </div>
              <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 16 }}>
                <div style={{ color: p.muted, fontSize: 11 }}>Varreduras feitas</div>
                <div style={{ color: "#60a5fa", fontSize: 30, fontWeight: 800 }}>{history.length}</div>
              </div>
              <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 16 }}>
                <div style={{ color: p.muted, fontSize: 11 }}>Últimos resultados</div>
                <div style={{ color: "#f59e0b", fontSize: 30, fontWeight: 800 }}>{jobs.length}</div>
              </div>
            </div>

            <div style={{ display: "flex", gap: 8, flexWrap: "wrap", marginBottom: 16 }}>
              <button onClick={restoreLastResults} style={{ ...topBtn, borderColor: "#3b82f6", color: "#60a5fa" }}>↩ Restaurar últimos resultados</button>
              <button onClick={() => setTab("favorites")} style={{ ...topBtn, borderColor: "#16a34a", color: "#4ade80" }}>⭐ Ver favoritos</button>
              <button onClick={clearDashboardData} style={{ ...topBtn, borderColor: "#991b1b", color: "#f87171" }}>🗑 Limpar dados locais</button>
            </div>

            <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit,minmax(280px,1fr))", gap: 14 }}>
              <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 16 }}>
                <h3 style={{ marginTop: 0, color: p.text }}>⭐ Últimas vagas salvas</h3>
                {favorites.slice(0, 5).length ? favorites.slice(0, 5).map(f => (
                  <div key={favoriteKey(f)} style={{ borderTop: `1px solid ${p.border}`, padding: "9px 0", color: p.sub }}>
                    <strong style={{ color: p.text }}>{f.company}</strong><br/>
                    <span style={{ fontSize: 12 }}>{f.position} · {f.location}</span>
                  </div>
                )) : <div style={{ color: p.muted }}>Nenhuma vaga salva ainda.</div>}
              </div>

              <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 16 }}>
                <h3 style={{ marginTop: 0, color: p.text }}>🕘 Histórico recente</h3>
                {history.slice(0, 5).length ? history.slice(0, 5).map(h => (
                  <div key={h.id} style={{ borderTop: `1px solid ${p.border}`, padding: "9px 0", color: p.sub }}>
                    <strong style={{ color: p.text }}>{h.visaType} · {h.category}</strong><br/>
                    <span style={{ fontSize: 12 }}>{h.state} · {h.jobs} vagas · {h.ts}</span>
                  </div>
                )) : <div style={{ color: p.muted }}>Nenhuma varredura registrada.</div>}
              </div>
            </div>
          </div>}

          {tab === "favorites" && <div>
            {favorites.length ? favorites.map((j, i) => (
              <JobCard key={favoriteKey(j)} job={j} idx={i} vt={vt} p={p} visaType={visaType} meta={meta} isFavorite={isFavorite} onToggleFavorite={toggleFavorite} />
            )) : <div style={{ color: p.muted, background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 20 }}>
              Nenhuma vaga salva ainda. Clique em <strong>☆ Salvar</strong> em qualquer vaga para adicioná-la aqui.
            </div>}
          </div>}

          {tab === "terminal" && <div style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 10, padding: 16, color: p.sub, fontFamily: "'JetBrains Mono',monospace", minHeight: 120 }}>{logs.length ? logs.map((l, i) => <div key={i}><span style={{ color: p.muted }}>{String(i + 1).padStart(3, "0")}</span> {l}</div>) : "$ aguardando varredura..."}</div>}
          {tab === "history" && <div>{history.length ? history.map(h => <div key={h.id} style={{ background: p.card, border: `1px solid ${p.border}`, borderRadius: 9, padding: 12, marginBottom: 8, color: p.sub }}>{h.visaType} · {h.category} · {h.state} · {h.jobs} vagas · {h.ts}</div>) : <div style={{ color: p.muted }}>Nenhuma busca ainda.</div>}</div>}
          {!loading && jobs.length === 0 && logs.length === 0 && tab === "results" && <Empty vt={vt} p={p} />}
        </main>
      </div>
    </div>
    {showAdmin && <AdminPanel onClose={() => { setShowAdmin(false); refreshAiStatus(); }} />}
  </>;
}

function Empty({ vt, p }) {
  return <div style={{ textAlign: "center", padding: "64px 20px", color: p.muted }}><div style={{ fontSize: 52 }}>{vt.icon}</div><h2 style={{ color: p.text, fontFamily: "'Syne',sans-serif" }}>Configure e inicie a varredura</h2><p>Selecione visto, setor e estado. O motor de IA é escolhido automaticamente conforme configuração do servidor.</p></div>;
}
