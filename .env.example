# ─────────────────────────────────────────────────────────────────────────────
#  H-2 Visa Scanner Pro v2 — Variáveis de Ambiente
#  cp .env.example .env  →  edite com seus valores
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production

# ── Segurança JWT (TROQUE para uma string longa e aleatória em produção!) ────
JWT_SECRET=mude_esta_chave_para_algo_seguro_em_producao_2026
JWT_EXPIRES_IN=8h

# ── Credenciais do admin padrão (criado na primeira execução) ────────────────
ADMIN_PASSWORD=admin123

# ── Caminho do banco SQLite ──────────────────────────────────────────────────
DB_PATH=./data/scanner.db

# ── Chaves de API (mínimo 1 obrigatório) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-...
